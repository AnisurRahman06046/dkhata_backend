generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  telegramId      String   @unique
  name            String
  phone           String?
  language        String   @default("en")
  initialBalance  Decimal  @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales        Sale[]
  expenses     Expense[]
  dailyLedgers DailyLedger[]

  @@index([telegramId])
}

model Sale {
  id             String   @id @default(uuid())
  userId         String
  productName    String
  price          Decimal  @db.Decimal(12, 2)
  quantity       Int      @default(1)
  syncedToSheets Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Expense {
  id             String   @id @default(uuid())
  userId         String
  description    String
  amount         Decimal  @db.Decimal(12, 2)
  syncedToSheets Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model DailyLedger {
  id              String   @id @default(uuid())
  userId          String
  date            String
  openingBalance  Decimal  @db.Decimal(12, 2)
  totalSales      Decimal  @default(0) @db.Decimal(12, 2)
  totalExpenses   Decimal  @default(0) @db.Decimal(12, 2)
  closingBalance  Decimal  @db.Decimal(12, 2)
  isClosed        Boolean  @default(false)
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}
