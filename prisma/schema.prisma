generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  PRO_MONTHLY
  PRO_YEARLY
}

enum PaymentMethod {
  BKASH
  NAGAD
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id              String   @id @default(uuid())
  telegramId      String   @unique
  name            String
  phone           String?
  language        String   @default("en")
  initialBalance  Decimal  @default(0) @db.Decimal(12, 2)
  plan            PlanType @default(FREE)
  planExpiresAt   DateTime?
  referralCode    String   @unique @default(uuid())
  streakDays      Int      @default(0)
  lastActiveDate  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales        Sale[]
  expenses     Expense[]
  dailyLedgers DailyLedger[]
  payments     Payment[]
  referralsSent Referral[] @relation("referrer")
  referralsReceived Referral[] @relation("referred")

  @@index([telegramId])
  @@index([referralCode])
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  transactionId String
  planType      PlanType
  status        PaymentStatus @default(PENDING)
  verifiedBy    String?
  verifiedAt    DateTime?
  rejectedReason String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([transactionId])
}

model Referral {
  id          String   @id @default(uuid())
  referrerId  String
  referredId  String
  rewarded    Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer User @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referrerId])
}

model Sale {
  id             String   @id @default(uuid())
  userId         String
  productName    String
  price          Decimal  @db.Decimal(12, 2)
  quantity       Int      @default(1)
  syncedToSheets Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Expense {
  id             String   @id @default(uuid())
  userId         String
  description    String
  amount         Decimal  @db.Decimal(12, 2)
  syncedToSheets Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model DailyLedger {
  id              String    @id @default(uuid())
  userId          String
  date            String
  openingBalance  Decimal   @db.Decimal(12, 2)
  totalSales      Decimal   @default(0) @db.Decimal(12, 2)
  totalExpenses   Decimal   @default(0) @db.Decimal(12, 2)
  closingBalance  Decimal   @db.Decimal(12, 2)
  isClosed        Boolean   @default(false)
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}
